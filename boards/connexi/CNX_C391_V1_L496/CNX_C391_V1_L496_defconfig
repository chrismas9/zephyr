# enable uart driver
CONFIG_SERIAL=y
CONFIG_UART_INTERRUPT_DRIVEN=y

# enable GPIO
CONFIG_GPIO=y

# enable I2C
CONFIG_I2C=y

# enable SPI
CONFIG_SPI=y

# enable CAN
CONFIG_CAN=y

# enable RTC
CONFIG_RTC=y

# enable ADC
CONFIG_ADC=y

# enable DAC
CONFIG_DAC=y

# enable clock
CONFIG_CLOCK_CONTROL=y

# console
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# enable MPU
CONFIG_ARM_MPU=y

# Enable HW stack protection
CONFIG_HW_STACK_PROTECTION=y

# enable pin controller
CONFIG_PINCTRL=y
